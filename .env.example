# Copy to .env and fill in your own keys. .env is gitignored.

# Financial Modeling Prep — fundamentals, peers, profiles (https://site.financialmodelingprep.com)
FMP_API_KEY=your_fmp_api_key_here

# FRED — macro series (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# SEC EDGAR requires a descriptive User-Agent with a contact email
EDGAR_USER_AGENT=your_email@example.com

# Optional: Feishu/Lark Bitable push for momentum-scan results (leave blank to disable)
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
